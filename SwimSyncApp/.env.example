# SwimSync mobile app — Supabase connection
# Local dev (iOS simulator / web): use the URL/key printed by `supabase start`.
# Physical device: replace 127.0.0.1 with your machine's LAN IP.
# Cloud: use your project's URL + anon (publishable) key from the dashboard.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
