# SwimSync admin panel — Supabase connection
# Values from `supabase start` (local) or the dashboard (cloud).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser or commit a real value.
# Used by the create-coach API route (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret used to authenticate the generate-invoices Edge Function.
# Must match supabase/functions/.env (local) or the deployed function secret.
CRON_SECRET=local-dev-cron-secret
