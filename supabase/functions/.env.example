# Env for `supabase functions serve generate-invoices --env-file supabase/functions/.env`.
# Copy to `.env` (git-ignored) and fill in. SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
# are injected automatically by the local functions runtime, so they aren't listed here.

# Shared secret the Edge Function checks on the Authorization header (Bearer <CRON_SECRET>).
# Local dev uses the same value in SwimSyncAdmin/.env.local so the admin route can call it.
CRON_SECRET=local-dev-cron-secret

# Resend API key for invoice-notification emails. Same key used as the SMTP password
# on the cloud project. OPTIONAL: when unset, the function skips sending (a logged
# no-op) and invoice generation is unaffected — so local dev leaves this blank.
# On the CLOUD project set it as a secret instead of here:
#   supabase secrets set RESEND_API_KEY=<your Resend API key>
# RESEND_API_KEY=

# Base URL used for the "View invoice in the app" button in the email.
# Defaults to https://swimsync.sg when unset.
# APP_URL=https://swimsync.sg
